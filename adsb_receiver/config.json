{
  "name": "ADSB Receiver",
  "version": "1.0.0",
  "slug": "adsb_receiver",
  "description": "ADS-B receiver using dump1090-fa, targeted at a specific RTL-SDR serial number",
  "url": "https://github.com/YOUR_GITHUB_USERNAME/adsb-addon",
  "arch": ["amd64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "options": {
    "serial": "00000002",
    "lat": 51.5,
    "lon": -0.1,
    "gain": "auto"
  },
  "schema": {
    "serial": "str",
    "lat": "float",
    "lon": "float",
    "gain": "str"
  },
  "ports": {
    "8080/tcp": 8080
  },
  "ports_description": {
    "8080/tcp": "dump1090 web map"
  },
  "devices": [
    "/dev/bus/usb"
  ],
  "privileged": ["SYS_RAWIO"],
  "hassio_api": false,
  "homeassistant_api": false,
  "ingress": true,
  "ingress_port": 8080,
  "panel_icon": "mdi:airplane",
  "panel_title": "ADSB Map"
}
